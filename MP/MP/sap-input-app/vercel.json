{
  "functions": {
    "api/**/*": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/send-wa-image",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/send-wa-image",
      "schedule": "0 8 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pmreg5.vercel.app"
        }
      ],
      "destination": "https://pmreg5.afratarigan.my.id/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pmreg5-.*-keyusersapreg5-5782s-projects.vercel.app"
        }
      ],
      "destination": "https://pmreg5.afratarigan.my.id/$1",
      "permanent": true
    }
  ]
}
